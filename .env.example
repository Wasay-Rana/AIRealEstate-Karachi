# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# ── Embeddings ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Pinecone ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=graph-rag-agent
PINECONE_ENVIRONMENT=us-east-1

# ── LightRAG ─────────────────────────────────────────────────────────────────
LIGHTRAG_WORKING_DIR=./lightrag_storage

# ── Retrieval ────────────────────────────────────────────────────────────────
DEFAULT_RETRIEVAL_MODE=balanced
MAX_CONTEXT_TOKENS=6000
RERANKER_TOP_N=8
PINECONE_TOP_K=20
BM25_TOP_K=15
LIGHTRAG_TOP_K=15

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
VERSION=1.0.0
